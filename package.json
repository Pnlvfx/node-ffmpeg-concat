{
  "name": "node-ffmpeg-concat",
  "version": "2025.13.0",
  "description": "Concats a list of videos together using ffmpeg with sexy OpenGL transitions.",
  "keywords": [
    "ffmpeg",
    "fluent-ffmpeg",
    "opengl",
    "gl",
    "gl-transition",
    "transition",
    "concat",
    "concatenate",
    "video"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/node-ffmpeg-concat.git"
  },
  "license": "MIT",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/ffmpeg-concat.d.ts",
      "import": "./dist/ffmpeg-concat.js",
      "require": "./dist/ffmpeg-concat.js"
    }
  },
  "main": "./dist/ffmpeg-concat.js",
  "module": "./dist/ffmpeg-concat.js",
  "types": "./dist/ffmpeg-concat.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json && eslint",
    "dev": "node tools/cli.ts",
    "lint": "eslint",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "test": "rimraf coverage && yarn node --experimental-vm-modules $(yarn bin jest) --verbose --coverage",
    "tsc": "tsc --noEmit",
    "update": "yarn upgrade-interactive"
  },
  "dependencies": {
    "get-pixels": "github:scijs/get-pixels",
    "gl": "^9.0.0-rc.9",
    "gl-buffer": "^2.1.2",
    "gl-shader": "^4.3.1",
    "gl-texture2d": "^2.1.0",
    "gl-transitions": "^1.71.0",
    "hh-mm-ss": "^1.2.0",
    "ndarray": "^1.0.19",
    "p-map": "^7.0.5",
    "rmrf": "^2.0.4",
    "tempy": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/config-helpers": "^0.6.0",
    "@goatjs/dbz": "^2.56.0",
    "@goatjs/doctor": "^2.47.0",
    "@goatjs/node-eslint": "^3.2.0",
    "@goatjs/rimraf": "^2.12.0",
    "@goatjs/typescript-config": "^2.2.0",
    "@jest/globals": "^30.4.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/get-pixels": "^3.3.4",
    "@types/gl": "^6.0.5",
    "@types/gl-shader": "^4.2.5",
    "@types/gl-texture2d": "^2.1.6",
    "@types/hh-mm-ss": "^1.2.3",
    "@types/node": "^26.1.1",
    "async-ffmpeg": "^2025.8.30",
    "eslint": "^10.7.0",
    "fluent-ffmpeg": "^2.1.3",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "async-ffmpeg": "^2025.7.31",
    "fluent-ffmpeg": "*",
    "sharp": "*"
  },
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697"
}
